# Database (swap sqlite for postgres in production)
DATABASE_URL=sqlite+aiosqlite:///./returns.db

# Return policy
RETURN_WINDOW_DAYS=30

# Decision thresholds
REFUND_THRESHOLD_AMOUNT=500.0
HIGH_VALUE_MANUAL_REVIEW=true

# Comma/JSON list of product types that cannot be returned
# RESTRICTED_PRODUCT_TYPES=["digital","perishable"]
