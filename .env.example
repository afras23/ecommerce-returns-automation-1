# Logging
LOG_LEVEL=INFO

# Database (use async URL; sqlite for local dev, postgres in Docker / prod)
DATABASE_URL=sqlite+aiosqlite:///./returns.db
# DATABASE_URL=postgresql+asyncpg://returns:returns@localhost:5432/returns

# Return policy
RETURN_WINDOW_DAYS=30

# Decision thresholds
REFUND_THRESHOLD_AMOUNT=500.0
HIGH_VALUE_MANUAL_REVIEW=true
AUTO_APPROVE_SCORE=0.70

# Comma-separated or JSON list
# RESTRICTED_PRODUCT_TYPES=["digital","perishable"]

# AI (mock avoids external calls)
AI_PROVIDER=mock
AI_MODEL=gpt-4o-mini
# AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1

# Rate limiting (requests per minute per client)
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# Metrics
METRICS_ENABLED=true
