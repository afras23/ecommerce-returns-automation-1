# Copy to .env and adjust. Never commit .env (real secrets).
# All variables map to app.config.Settings (Pydantic, case-insensitive env names).

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# Async SQLAlchemy URL. Dev: SQLite file. Prod: Postgres recommended.
DATABASE_URL=sqlite+aiosqlite:///./returns.db
# DATABASE_URL=postgresql+asyncpg://returns:CHANGE_ME@localhost:5432/returns

# -----------------------------------------------------------------------------
# Return policy & decisions
# -----------------------------------------------------------------------------
RETURN_WINDOW_DAYS=30
REFUND_THRESHOLD_AMOUNT=500.0
HIGH_VALUE_MANUAL_REVIEW=true
AUTO_APPROVE_SCORE=0.70

# Comma-separated or JSON array, e.g. ["digital","perishable"]
# RESTRICTED_PRODUCT_TYPES=

# -----------------------------------------------------------------------------
# AI provider (use mock for CI / local without external calls)
# -----------------------------------------------------------------------------
AI_PROVIDER=mock
AI_MODEL=gpt-4o-mini
# AI_API_KEY=sk-proj-replace-me
AI_BASE_URL=https://api.openai.com/v1
AI_TIMEOUT_SECONDS=60.0
AI_MAX_RETRIES=3
AI_RETRY_BASE_DELAY_SECONDS=0.5
AI_COST_PER_1K_INPUT_TOKENS_USD=0.00015
AI_COST_PER_1K_OUTPUT_TOKENS_USD=0.0006

# -----------------------------------------------------------------------------
# Rate limiting & metrics
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=120
METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# Fraud scoring (deterministic; no AI)
# -----------------------------------------------------------------------------
FRAUD_WINDOW_DAYS=30
FRAUD_FREQUENCY_HIGH_COUNT=5
FRAUD_TOTAL_VALUE_HIGH_USD=1500.0
FRAUD_AVG_ORDER_VALUE_HIGH_USD=300.0
FRAUD_RECENCY_HOT_DAYS=3
FRAUD_WEIGHT_FREQUENCY=0.45
FRAUD_WEIGHT_VALUE=0.35
FRAUD_WEIGHT_RECENCY=0.20
FRAUD_RISK_MEDIUM_MIN=0.35
FRAUD_RISK_HIGH_MIN=0.65
FRAUD_FLAGGED_PROCESSING_THRESHOLD=0.65

# -----------------------------------------------------------------------------
# Refund rules (rule engine; not LLM)
# -----------------------------------------------------------------------------
RESTOCKING_FEE_PERCENT=0.0
